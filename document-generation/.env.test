# Loaded by core/config.py when ENV=test is exported (e.g. by tests/conftest.py).
# Tests are hermetic: NATS and object storage are fully mocked, nothing real is
# contacted. These are placeholders only.

# ── Core ──
ENV=test

# ── NATS ──
# Empty: the worker is not initialised under tests; NATS clients are mocked.
NATS_URL=

# ── JetStream topology ──
DOCGEN_REQUEST_STREAM=DOCGEN_REQUESTS
DOCGEN_REQUEST_SUBJECT=docgen.request
DOCGEN_DURABLE=worker-docgen
DOCGEN_RESULTS_STREAM=DOCGEN_RESULTS
DOCGEN_RESULTS_SUBJECT_FILTER=docgen.result.>
DOCGEN_DLQ_STREAM=DOCGEN_DLQ
DOCGEN_DLQ_SUBJECT=docgen.dlq
DOCGEN_MAX_DELIVER=4
DOCGEN_ACK_WAIT_SECONDS=600
DOCGEN_NAK_RETRY_DELAY_SECONDS=30

# ── Rendering ──
RENDER_POOL_SIZE=0
TEMPLATE_CACHE_DIR=/tmp/docgen-templates-test

# ── Storage ──
# Placeholders only — tests mock the storage adapter entirely.
STORAGE_ENDPOINT=http://localhost:9999
TEMPLATES_BUCKET=optimce-templates
OUTPUT_BUCKET=optimce-documents
STORAGE_ACCESS_KEY=test-access
STORAGE_SECRET_KEY=test-secret
STORAGE_REGION=us-east-1

# ── Observability ──
LOGGING_TOKEN=
LOGGING_TRACES_URL=
LOGGING_LOGS_URL=
LOGGING_METRICS_URL=
